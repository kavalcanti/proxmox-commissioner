#!/bin/bash
# Service Configuration: service-template
# Sourced after config/infrastructure.env and config/local.env.
# Only service-specific values and overrides belong here.
# Do not set PROJECT_ROOT or shared paths.

# ==============================================================================
# VM SPECIFICATIONS (REQUIRED)
# ==============================================================================
export TF_VAR_vm_name="service-template"                # Name for the VM
export TF_VAR_vm_id="1000"                              # ID for the VM
export TF_VAR_vm_cores="1"                              # Number of cores
export TF_VAR_vm_sockets="1"                            # Number of sockets
export TF_VAR_vm_memory="1024"                          # Amount of memory in MB
export TF_VAR_vm_disk_size="16"                         # Disk size in GB

# ==============================================================================
################################################################################
# BELOW ARE OPTIONAL OVERRIDES (uncomment to bypass defaults)                  #
################################################################################
# ==============================================================================

# ==============================================================================
# PROXMOX CLUSTER DESTINATION NODE OVERRIDES
# ==============================================================================
# export TF_VAR_proxmox_endpoint="https://172.20.10.110:8006/"
# export TF_VAR_proxmox_ssh_user="root"
# export PROXMOX_SSH_KEY="/home/kaoue/.ssh/earthcentral"
# export TF_VAR_proxmox_node="occamsrazor"
# export TF_VAR_proxmox_node_ip="172.20.10.110"

# ==============================================================================
# TEMPLATE CONFIGURATION OVERRIDES (MUST EXIST ON THE DESTINATION NODE)
# ==============================================================================
# export TF_VAR_template_id="9001"        # Source Template VM ID to clone from
# export TF_VAR_clone_full="true"         # Full clone (true) or linked clone
# export TF_VAR_proxmox_destination_node=""       # Node to migrate VM to after
#                                                 # cloning (empty = no migration)
# export TF_VAR_proxmox_destination_node_ip=""    # Destination node IP (for
#                                                 # reference / future use)

# ==============================================================================
# PROXMOX API CREDENTIALS
# ==============================================================================
# Create an API token in Proxmox:
# Datacenter > Permissions > API Tokens > Add
# Format: username@realm!tokenid=secret
# export TF_VAR_proxmox_api_token="root@pam!lab=52208a63-35a4-4883-b3fe-a010f79b3b70"

# ==============================================================================
# VM PASSWORDS
# ==============================================================================
# Initial root password for VM (set via cloud-init)
# export TF_VAR_root_password="0101"

# ==============================================================================
# SSH KEYS
# ==============================================================================
# Public SSH key to add to the VM (optional, for key-based auth)
# export TF_VAR_ssh_public_key=""

# ==============================================================================
# STORAGE CONFIGURATION (defaults, override per-service if needed)
# ==============================================================================
# export TF_VAR_datastore_disk="local-lvm"        # Datastore for VM disk
# export TF_VAR_datastore_snippets="local"        # Datastore for cloud-init snippets
# export TF_VAR_datastore_cloudinit="local-lvm"   # Datastore for cloud-init drive
# export TF_VAR_disk_interface="scsi0"            # Disk controller interface (scsi0,
#                                                 # sata0, etc)
# export TF_VAR_disk_discard="on"                 # Enable TRIM/discard for SSD

# ==============================================================================
# NETWORK OVERRIDES
# ==============================================================================
# export TF_VAR_network_bridge="vmbr0"            # Network bridge to attach VM to
# export TF_VAR_network_model="virtio"            # Network adapter model
export TF_VAR_network_vlan_id="30"               # VLAN tag (0 = untagged)
# export TF_VAR_network_mode="dhcp"               # "dhcp" or "static"
# export TF_VAR_network_ip=""                     # e.g., "172.20.0.230/24" (if
#                                                 # static)
# export TF_VAR_network_gateway=""                # e.g., "172.20.0.1" (if static)

# ==============================================================================
# CLOUD-INIT OVERRIDES
# ==============================================================================
export TF_VAR_enable_qemu_agent="true"          # Enable QEMU guest agent
export TF_VAR_package_update="true"             # Update package cache on boot
export TF_VAR_package_upgrade="false"           # Upgrade packages on boot




