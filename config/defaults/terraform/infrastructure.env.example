#!/bin/bash
# Shared Infrastructure Defaults
# Sourced before per-service config. Values here act as cluster-wide defaults
# and can be overridden in config/<service>/<service>.infrastructure.env.

# ==============================================================================
# PROXMOX CLUSTER CONNECTION
# ==============================================================================
# To generate an SSH key:
# ssh-keygen -t ed25519 -f ~/.ssh/ansible_keys/your-vm-name -C "ansible@your-vm"

export TF_VAR_proxmox_endpoint="https://your-proxmox-host:8006/"
export TF_VAR_proxmox_ssh_user="root"
export PROXMOX_SSH_KEY="/path/to/your/proxmox/ssh/key"

# ==============================================================================
# PROXMOX NODE FOR VM CREATION
# ==============================================================================
# Set default for the same node as the cluster connection
# Override in service config if needed
export TF_VAR_proxmox_node="your-proxmox-node-name"
export TF_VAR_proxmox_node_ip="your-proxmox-node-ip"

# ==============================================================================
# PROXMOX API CREDENTIALS
# ==============================================================================
# Create an API token in Proxmox:
# Datacenter > Permissions > API Tokens > Add
# Format: username@realm!tokenid=secret
export TF_VAR_proxmox_api_token="your-proxmox-api-token"

# ==============================================================================
# VM PASSWORDS
# ==============================================================================
# Initial root password for VM (for cloud-init setup)
export TF_VAR_root_password="your-root-password"

# ==============================================================================
# SSH KEYS
# ==============================================================================
# Public SSH key to add to the VM (optional, for key-based auth on cloud-init
# setup) Default is empty, so no key-based auth is used, as Ansible handles VM
# hardening, including SSH auth.

export TF_VAR_ssh_public_key="your-ssh-public-key"

# ==============================================================================
# TEMPLATE CONFIGURATION
# ==============================================================================
# Source Template VM ID to clone from. Template must exist on the Proxmox node.

export TF_VAR_template_id="9000"        # Source Template VM ID to clone from
export TF_VAR_clone_full="true"         # Full clone (true) or linked clone
export TF_VAR_proxmox_destination_node=""       # Node to migrate VM to after
                                                # cloning (empty = no migration)
export TF_VAR_proxmox_destination_node_ip=""    # Destination node IP (for
                                                # reference / future use)

# ==============================================================================
# STORAGE CONFIGURATION (defaults, override per-service if needed)
# ==============================================================================
export TF_VAR_datastore_disk="local-lvm"        # Datastore for VM disk
export TF_VAR_datastore_snippets="local"        # Datastore for cloud-init snippets
export TF_VAR_datastore_cloudinit="local-lvm"   # Datastore for cloud-init drive
export TF_VAR_disk_interface="scsi0"            # Disk controller interface (scsi0,
                                                # sata0, etc)
export TF_VAR_disk_discard="on"                 # Enable TRIM/discard for SSD

# ==============================================================================
# NETWORK CONFIGURATION (defaults, override per-service if needed)
# ==============================================================================
export TF_VAR_network_bridge="vmbr0"            # Network bridge to attach VM to
export TF_VAR_network_model="virtio"            # Network adapter model
export TF_VAR_network_vlan_id="0"               # VLAN tag (0 = untagged)
export TF_VAR_network_mode="dhcp"               # "dhcp" or "static"
export TF_VAR_network_ip=""                     # e.g., "172.20.0.230/24" (if
                                                # static)
export TF_VAR_network_gateway=""                # e.g., "172.20.0.1" (if static)

# ==============================================================================
# CLOUD-INIT CONFIGURATION
# ==============================================================================
export TF_VAR_enable_qemu_agent="true"          # Enable QEMU guest agent
export TF_VAR_package_update="true"             # Update package cache on boot
export TF_VAR_package_upgrade="false"           # Upgrade packages on boot
# Debian cloud image default user (UID 1000). Removing it frees 1000 for devops. Use "" to keep it.
export TF_VAR_remove_distro_cloud_user="debian"

