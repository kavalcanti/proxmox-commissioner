#!/bin/bash
# Local and additional configuration - EXAMPLE FILE
# Copy this file to local.env and fill in your actual values
# local.env is gitignored and will not be committed

# ==============================================================================
# ANSIBLE VAULT PASSWORD (optional)
# ==============================================================================
# If you want to avoid typing the vault password interactively
# export ANSIBLE_VAULT_PASSWORD="your-vault-password"
# OR set ANSIBLE_VAULT_PASSWORD_FILE to a file containing the password
# export ANSIBLE_VAULT_PASSWORD_FILE="${CONFIG_DIR}/.vault_pass"

# ==============================================================================
# ANSIBLE CONFIGURATION (defaults, override per-service if needed)
# ==============================================================================
export ANSIBLE_CONFIG="${ANSIBLE_DIR}/ansible.cfg"       # Path to Ansible configuration
export ANSIBLE_INVENTORY="${CONFIG_DIR}/ansible" # Path to Ansible inventory

# ==============================================================================
# ANSIBLE VAULT PASSWORD (optional)
# ==============================================================================
# If you want to avoid typing the vault password interactively
export ANSIBLE_VAULT_PASSWORD_FILE="${CONFIG_DIR}/defaults/ansible/.vaultpass"

# ==============================================================================
# ANSIBLE CONFIGURATION (defaults, override per-service if needed)
# ==============================================================================
export ANSIBLE_CONFIG="${ANSIBLE_DIR}/ansible.cfg"       # Path to Ansible configuration
export ANSIBLE_INVENTORY="${CONFIG_DIR}/ansible" # Path to Ansible inventory
